{
    "manifest_version": 3,
    "name": "Extension",
    "version": "1.0",
    "description": "This is a test extension for security demonstration.",
    "permissions": [
        "scripting",
        "tabs",
        "cookies"
    ],
    "host_permissions": [
        "<all_urls>",
        "http://127.0.0.1/*",
        "http://localhost/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "action": {
        "default_title": "Test"
    }
}